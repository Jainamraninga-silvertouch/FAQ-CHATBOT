# Example environment configuration for FAQ Chatbot
# Copy this file to `.env` and fill in your real values. Do NOT commit
# the real `.env` file to version control.

# Groq API Key - Get yours from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: model to use
# GROQ_MODEL=llama-3.3-70b-versatile
